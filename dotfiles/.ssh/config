# Rental-point routers over the WireGuard tunnel (bring up with: sudo wg-quick up veloking).
# Each site = 10.0.0.(N+1): site 1 (TGP)=10.0.0.2, site 2=10.0.0.4, site 3=10.0.0.5, ...
Host router
  User root
  HostName 10.0.0.2
  IdentityFile ~/.ssh/veloking_deploy
  StrictHostKeyChecking accept-new

